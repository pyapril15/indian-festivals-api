# ==============================================================================
# APPLICATION CONFIGURATION TEMPLATE (.env.example)
# Rename this file to .env and configure the variables accordingly.
# ==============================================================================

# Application Setup
APP_NAME="Indian Festivals API"
APP_VERSION="1.0.1"
APP_DESCRIPTION="Comprehensive API for Indian festivals, holidays, and celebrations"
DEBUG="true"  # Set to "false" in production environments

# Server Infrastructure
HOST="127.0.0.1"
PORT=8000

# API Versioning Prefix
API_V1_PREFIX="/api/v1"

# Rate Limiting Safety Rules
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60  # in seconds

# Cache Lifespan (1 Hour)
CACHE_TTL=3600  # in seconds

# CORS Allowed Entrypoints (JSON list format)
CORS_ORIGINS='["http://localhost:3000", "http://localhost:5173"]'
CORS_ALLOW_CREDENTIALS="true"
CORS_ALLOW_METHODS='["GET", "OPTIONS"]'
CORS_ALLOW_HEADERS='["*"]'

# Scraper System Rules
SCRAPER_TIMEOUT=30
SCRAPER_BASE_URL="https://panchang.astrosage.com/calendars/indiancalendar"

# Operational Bounds Validation
MIN_YEAR=1900
MAX_YEAR=2100
MIN_MONTH=1
MAX_MONTH=12
